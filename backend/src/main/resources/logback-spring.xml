<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- MDC-enriched pattern: timestamp | level | thread | logger | requestId | userId | message -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} %-5level [%15.15thread] %40.40logger{40} [rid=%X{requestId:-–}] [uid=%X{userId:-–}] – %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Rolling file appender – writes to logs/application.log, rolls daily, keeps 30 days -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Application code: DEBUG in dev, INFO in prod -->
    <springProfile name="!prod">
        <logger name="com.manager" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>
    <springProfile name="prod">
        <logger name="com.manager" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>

    <!-- Suppress noisy third-party loggers -->
    <logger name="org.springframework.security"           level="WARN"/>
    <logger name="org.springframework.web"                level="WARN"/>
    <logger name="com.google.cloud.firestore"             level="WARN"/>
    <logger name="io.grpc"                                level="WARN"/>
    <logger name="okhttp3"                                level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
